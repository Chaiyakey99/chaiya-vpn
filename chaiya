#!/bin/bash

clear
echo "🔥 CHAIYA VPN PRO MAX 🔥"
echo "========================"
echo "1. ตรวจสอบระบบ"
echo "2. รีสตาร์ท Xray"
echo "3. ดูผู้ใช้งานออนไลน์"
echo "0. ออก"
echo "========================"
read -p "เลือกเมนู: " opt

case $opt in
1)
echo "📊 สถานะระบบ"
uptime
;;
2)
echo "🔄 รีสตาร์ท Xray..."
systemctl restart xray 2>/dev/null
echo "✅ เสร็จแล้ว"
;;
3)
echo "👥 ผู้ใช้งานออนไลน์"
netstat -tnp | grep ESTABLISHED
;;
0)
exit
;;
*)
echo "❌ เลือกผิด"
;;
esac
